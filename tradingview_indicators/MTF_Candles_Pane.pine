//@version=5
indicator("MTF Candles - Bottom Pane", overlay=false, max_boxes_count=500, max_lines_count=500, max_labels_count=100)

// ==========================================
// CÀI ĐẶT / INPUTS
// ==========================================
gp_tf1 = "Khung thời gian 1 (4H)"
show_tf1 = input.bool(true, "Hiển thị TF1 (4H)", group=gp_tf1)
tf1_val  = input.timeframe("240", "Khung thời gian TF1", group=gp_tf1)
tf1_bull = input.color(color.new(#26a69a, 85), "Màu nến Tăng TF1", group=gp_tf1)
tf1_bear = input.color(color.new(#ef5350, 85), "Màu nến Giảm TF1", group=gp_tf1)
tf1_wick = input.color(color.new(#787b86, 50), "Màu râu & viền TF1", group=gp_tf1)

gp_tf2 = "Khung thời gian 2 (1D)"
show_tf2 = input.bool(true, "Hiển thị TF2 (1D)", group=gp_tf2)
tf2_val  = input.timeframe("D", "Khung thời gian TF2", group=gp_tf2)
tf2_bull = input.color(color.new(#2196f3, 90), "Màu nến Tăng TF2", group=gp_tf2)
tf2_bear = input.color(color.new(#ff9800, 90), "Màu nến Giảm TF2", group=gp_tf2)
tf2_wick = input.color(color.new(#b2b5be, 60), "Màu râu & viền TF2", group=gp_tf2)

gp_gen   = "Cài đặt chung"
display_mode = input.string("Phía bên phải", "Chế độ hiển thị", options=["Đè lên nến lịch sử", "Phía bên phải"], group=gp_gen)
max_candles  = input.int(10, "Số lượng nến hiển thị", minval=1, maxval=100, group=gp_gen)

gp_side  = "Cấu hình hiển thị Phía bên phải"
offset       = input.int(5, "Khoảng cách so với nến mới nhất (bars)", minval=1, group=gp_side)
candle_w     = input.int(3, "Độ rộng của mỗi cây nến (bars)", minval=1, maxval=15, group=gp_side)
candle_s     = input.int(1, "Khoảng cách giữa các nến (bars)", minval=0, maxval=5, group=gp_side)
group_s      = input.int(5, "Khoảng cách giữa 2 khung (bars)", minval=1, maxval=20, group=gp_side)

// ==========================================
// LẤY DỮ LIỆU ĐA KHUNG THỜI GIAN
// ==========================================
f_get_data(tf) =>
    [o, h, l, c, t, tc] = request.security(syminfo.tickerid, tf, [open, high, low, close, time, time_close], gaps=barmerge.gaps_off)
    [o, h, l, c, t, tc]

[tf1_o, tf1_h, tf1_l, tf1_c, tf1_t, tf1_tc] = f_get_data(tf1_val)
[tf2_o, tf2_h, tf2_l, tf2_c, tf2_t, tf2_tc] = f_get_data(tf2_val)

is_lower_tf1 = timeframe.in_seconds(timeframe.period) < timeframe.in_seconds(tf1_val)
is_lower_tf2 = timeframe.in_seconds(timeframe.period) < timeframe.in_seconds(tf2_val)

// ==========================================
// MẢNG LƯU LỊCH SỬ NẾN CHO PHƯƠNG THỨC SIDEBAR
// ==========================================
var float[] tf1_opens = array.new_float()
var float[] tf1_highs = array.new_float()
var float[] tf1_lows = array.new_float()
var float[] tf1_closes = array.new_float()

var float[] tf2_opens = array.new_float()
var float[] tf2_highs = array.new_float()
var float[] tf2_lows = array.new_float()
var float[] tf2_closes = array.new_float()

// Theo dõi khi nến HTF đóng
tf1_changed = ta.change(tf1_t) != 0
tf2_changed = ta.change(tf2_t) != 0

if tf1_changed and not barstate.isfirst
    array.push(tf1_opens, tf1_o[1])
    array.push(tf1_highs, tf1_h[1])
    array.push(tf1_lows, tf1_l[1])
    array.push(tf1_closes, tf1_c[1])
    if array.size(tf1_opens) > max_candles - 1
        array.shift(tf1_opens)
        array.shift(tf1_highs)
        array.shift(tf1_lows)
        array.shift(tf1_closes)

if tf2_changed and not barstate.isfirst
    array.push(tf2_opens, tf2_o[1])
    array.push(tf2_highs, tf2_h[1])
    array.push(tf2_lows, tf2_l[1])
    array.push(tf2_closes, tf2_c[1])
    if array.size(tf2_opens) > max_candles - 1
        array.shift(tf2_opens)
        array.shift(tf2_highs)
        array.shift(tf2_lows)
        array.shift(tf2_closes)

// ==========================================
// TỰ ĐỘNG CĂN CHỈNH TỶ LỆ Y-AXIS (AUTO-SCALE)
// ==========================================
var float overall_high = na
var float overall_low = na

overall_high := na
overall_low := na

f_get_limits(show, is_lower, highs_arr, lows_arr, curr_h, curr_l) =>
    float max_h = na
    float min_l = na
    if show and is_lower
        max_h := curr_h
        min_l := curr_l
        int size = array.size(highs_arr)
        if size > 0
            for i = 0 to size - 1
                max_h := math.max(max_h, array.get(highs_arr, i))
                min_l := math.min(min_l, array.get(lows_arr, i))
    [max_h, min_l]

[tf1_max_h, tf1_min_l] = f_get_limits(show_tf1, is_lower_tf1, tf1_highs, tf1_lows, tf1_h, tf1_l)
[tf2_max_h, tf2_min_l] = f_get_limits(show_tf2, is_lower_tf2, tf2_highs, tf2_lows, tf2_h, tf2_l)

if not na(tf1_max_h)
    overall_high := math.max(nz(overall_high, tf1_max_h), tf1_max_h)
if not na(tf1_min_l)
    overall_low := math.min(nz(overall_low, tf1_min_l), tf1_min_l)
    
if not na(tf2_max_h)
    overall_high := math.max(nz(overall_high, tf2_max_h), tf2_max_h)
if not na(tf2_min_l)
    overall_low := math.min(nz(overall_low, tf2_min_l), tf2_min_l)

// Vẽ ẩn bằng màu trong suốt (100% transparent) để trục tung tự căn chỉnh tỷ lệ
plot(overall_high, color=color.new(color.white, 100), editable=false)
plot(overall_low, color=color.new(color.white, 100), editable=false)

// ==========================================
// PHƯƠNG THỨC 1: ĐÈ LÊN NẾN LỊCH SỬ (OVERLAY)
// ==========================================
var box[] tf1_boxes = array.new_box()
var line[] tf1_wicks = array.new_line()

var box[] tf2_boxes = array.new_box()
var line[] tf2_wicks = array.new_line()

f_draw_candles(show, tf, o, h, l, c, t, tc, bull_col, bear_col, wick_col, boxes_arr, wicks_arr) =>
    is_lower_tf = timeframe.in_seconds(timeframe.period) < timeframe.in_seconds(tf)
    
    if show and is_lower_tf
        is_new = ta.change(t) != 0
        col = c >= o ? bull_col : bear_col
        mid_t = (t + tc) / 2
        top_y = math.max(o, c)
        bot_y = math.min(o, c)
        
        if is_new
            new_box = box.new(left=t, top=top_y, right=tc, bottom=bot_y, 
                              xloc=xloc.bar_time, bgcolor=col, border_color=wick_col, border_style=line.style_solid)
            new_wick = line.new(x1=mid_t, y1=h, x2=mid_t, y2=l, 
                                xloc=xloc.bar_time, color=wick_col, width=1)
            array.push(boxes_arr, new_box)
            array.push(wicks_arr, new_wick)
            
            if array.size(boxes_arr) > max_candles
                box.delete(array.shift(boxes_arr))
                line.delete(array.shift(wicks_arr))
        else
            if array.size(boxes_arr) > 0
                last_box = array.get(boxes_arr, array.size(boxes_arr) - 1)
                last_wick = array.get(wicks_arr, array.size(wicks_arr) - 1)
                
                box.set_left(last_box, t)
                box.set_right(last_box, tc)
                box.set_top(last_box, top_y)
                box.set_bottom(last_box, bot_y)
                box.set_bgcolor(last_box, col)
                box.set_border_color(last_box, wick_col)
                
                line.set_x1(last_wick, mid_t)
                line.set_y1(last_wick, h)
                line.set_x2(last_wick, mid_t)
                line.set_y2(last_wick, l)
                line.set_color(last_wick, wick_col)

if display_mode == "Đè lên nến lịch sử"
    f_draw_candles(show_tf1, tf1_val, tf1_o, tf1_h, tf1_l, tf1_c, tf1_t, tf1_tc, tf1_bull, tf1_bear, tf1_wick, tf1_boxes, tf1_wicks)
    f_draw_candles(show_tf2, tf2_val, tf2_o, tf2_h, tf2_l, tf2_c, tf2_t, tf2_tc, tf2_bull, tf2_bear, tf2_wick, tf2_boxes, tf2_wicks)

// ==========================================
// PHƯƠNG THỨC 2: HIỂN THỊ BÊN CẠNH (SIDEBAR PHÍA BÊN PHẢI)
// ==========================================
var box[] side_boxes = array.new_box()
var line[] side_wicks = array.new_line()
var label[] side_labels = array.new_label()

f_clear_side_drawings() =>
    while array.size(side_boxes) > 0
        box.delete(array.shift(side_boxes))
    while array.size(side_wicks) > 0
        line.delete(array.shift(side_wicks))
    while array.size(side_labels) > 0
        label.delete(array.shift(side_labels))

f_draw_future_candles(tf_name, opens_arr, highs_arr, lows_arr, closes_arr, curr_o, curr_h, curr_l, curr_c, start_x, width, spacing, bull_col, bear_col, wick_col, draw_boxes, draw_wicks, draw_labels) =>
    int size = array.size(opens_arr)
    
    for i = 0 to size
        float o = i < size ? array.get(opens_arr, i) : curr_o
        float h = i < size ? array.get(highs_arr, i) : curr_h
        float l = i < size ? array.get(lows_arr, i) : curr_l
        float c = i < size ? array.get(closes_arr, i) : curr_c
        
        int left_x = start_x + i * (width + spacing)
        int right_x = left_x + width
        int mid_x = left_x + math.round(width / 2)
        
        float top_y = math.max(o, c)
        float bot_y = math.min(o, c)
        color col = c >= o ? bull_col : bear_col
        
        new_box = box.new(left=left_x, top=top_y, right=right_x, bottom=bot_y,
                          xloc=xloc.bar_index, bgcolor=col, border_color=wick_col, border_style=line.style_solid)
        new_wick = line.new(x1=mid_x, y1=h, x2=mid_x, y2=l,
                            xloc=xloc.bar_index, color=wick_col, width=1)
        
        array.push(draw_boxes, new_box)
        array.push(draw_wicks, new_wick)
        
    float group_min_l = curr_l
    if size > 0
        for i = 0 to size - 1
            group_min_l := math.min(group_min_l, array.get(lows_arr, i))
            
    int label_x = start_x + (size * (width + spacing)) / 2
    new_label = label.new(x=label_x, y=group_min_l, text=tf_name, xloc=xloc.bar_index,
                          color=color.new(color.white, 100), textcolor=wick_col,
                          style=label.style_label_up, size=size.normal)
    array.push(draw_labels, new_label)

if barstate.islast
    f_clear_side_drawings()
    
    if display_mode == "Phía bên phải"
        int start_x1 = last_bar_index + offset
        
        if show_tf1 and is_lower_tf1
            f_draw_future_candles(tf1_val, tf1_opens, tf1_highs, tf1_lows, tf1_closes, 
                                  tf1_o, tf1_h, tf1_l, tf1_c, 
                                  start_x1, candle_w, candle_s, 
                                  tf1_bull, tf1_bear, tf1_wick, 
                                  side_boxes, side_wicks, side_labels)
        
        int num_candles_tf1 = (show_tf1 and is_lower_tf1) ? (array.size(tf1_opens) + 1) : 0
        int start_x2 = show_tf1 and is_lower_tf1 ? 
                       (start_x1 + num_candles_tf1 * (candle_w + candle_s) + group_s) : 
                       start_x1
                       
        if show_tf2 and is_lower_tf2
            f_draw_future_candles(tf2_val, tf2_opens, tf2_highs, tf2_lows, tf2_closes, 
                                  tf2_o, tf2_h, tf2_l, tf2_c, 
                                  start_x2, candle_w, candle_s, 
                                  tf2_bull, tf2_bear, tf2_wick, 
                                  side_boxes, side_wicks, side_labels)
